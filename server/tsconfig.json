{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "types": [
            "node",
            "express",
            "passport"
        ],
        "verbatimModuleSyntax": true,
        "noEmit": true
    },
    "include": [
        "src/**/*.ts"
    ]
}